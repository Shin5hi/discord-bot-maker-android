# Discord
DISCORD_TOKEN=pon_aqui_el_token_del_bot
TEAM_CHANNEL_ID=pon_aqui_el_id_del_canal

# Solo estas usuarias pueden arrancar o parar el equipo.
# Pon tu Discord user ID. Si lo dejas vacio, cualquier persona con acceso al canal podria usarlo.
OWNER_USER_IDS=

# Google AI Studio / Gemini
# Puedes usar una API distinta por agente, como habias planteado.
GEMINI_API_KEY_FREYJA=
GEMINI_API_KEY_SIGRID=
GEMINI_API_KEY_EIRA=
GEMINI_API_KEY_RUNE=

# Si prefieres probar rapido con una sola API para todas.
GEMINI_API_KEY=

# Cambialo desde .env si Google AI Studio te da otro modelo.
GEMINI_MODEL=gemini-2.5-flash

# Ritmo de conversacion
COMMAND_PREFIX=!
MAX_CONTEXT_MESSAGES=24
MAX_AGENT_WORDS=120
AUTO_TALK_ENABLED=false
AUTO_TALK_INTERVAL_MINUTES=45

# Opcional: avatares para que cada IA salga como "persona" por webhook.
AVATAR_FREYJA=
AVATAR_SIGRID=
AVATAR_EIRA=
AVATAR_RUNE=
